# Configuration des secrets pour le Chatbot Personnel
# Copiez ce fichier vers .streamlit/secrets.toml et remplissez vos vraies clés

# Clé API OpenAI (obligatoire)
OPENAI_API_KEY = "sk-votre-cle-openai-ici"

# Modèle OpenAI pour le worker (optionnel, défaut: gpt-5.5)
OPENAI_MODEL = "gpt-5.5"

# Clés Pushover (obligatoires pour les notifications)
# Obtenez-les sur: https://pushover.net
PUSHOVER_USER = "u-votre-user-key-ici"    # Commence par 'u'
PUSHOVER_TOKEN = "a-votre-token-app-ici"  # Commence par 'a